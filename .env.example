# Supabase credentials — get these from your Supabase project dashboard
# Settings → API → Project URL and anon/public key
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Admin password for the /Admin page
VITE_ADMIN_PASSWORD=your-admin-password-here

# EmailJS — optional, for email notifications on feedback form submissions
# Sign up at https://www.emailjs.com, create a service + email template, then paste the IDs below.
# If omitted, feedback is still saved to Supabase but no email is sent.
VITE_EMAILJS_SERVICE_ID=your-emailjs-service-id
VITE_EMAILJS_TEMPLATE_ID=your-emailjs-template-id
VITE_EMAILJS_PUBLIC_KEY=your-emailjs-public-key
